{
  "name": "flor-messenger",
  "version": "1.0.0",
  "description": "FLOR MESSENGER — чат с авторизацией, сообщениями и звонками",
  "main": "electron-main.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "electron": "electron .",
    "test:api": "node scripts/smoke-api.js",
    "build": "electron-builder"
  },
  "keywords": [
    "discord",
    "chat",
    "webrtc",
    "socketio",
    "video-call",
    "screen-sharing"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.4.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "selfsigned": "2.4.1",
    "socket.io": "^4.6.1",
    "sqlite3": "^5.1.6"
  },
  "devDependencies": {
    "electron": "^27.0.0",
    "electron-builder": "^24.6.4",
    "nodemon": "^3.0.1"
  },
  "build": {
    "appId": "com.flormessenger.app",
    "productName": "FLOR MESSENGER",
    "directories": {
      "output": "dist"
    },
    "asarUnpack": [
      "**/*.node",
      "node_modules/sqlite3/**"
    ],
    "files": [
      "**/*",
      "!node_modules/**/*",
      "node_modules/socket.io/**/*",
      "node_modules/socket.io-client/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon.png"
    }
  }
}
