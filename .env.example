# Скопируйте в .env на сервере и заполните (не коммитьте .env с секретами).

# Обязательно в production (веб на хостинге): случайная длинная строка
JWT_SECRET=

# Порт даёт хостинг (Render/Railway/Heroku) через PORT — обычно не трогайте
# PORT=3000

# Слушать все интерфейсы (по умолчанию уже 0.0.0.0 в коде)
# HOST=0.0.0.0

# За nginx/Caddy/Render: иначе rate-limit и IP могут вести себя странно
TRUST_PROXY=1

# Один origin или список через запятую; для «разрешить всё» в dev: true
# CORS_ORIGIN=https://ваш-домен.ru

# Микрофон / WebRTC / E2EE в браузере по IP: включите HTTPS (самоподписанный сертификат)
# USE_HTTPS=true
# Добавьте LAN-IP сервера, чтобы браузер принял сертификат при открытии https://IP:порт
# FLOR_TLS_SAN=localhost,127.0.0.1,192.168.0.10
# Или свои файлы вместо самоподписанного:
# SSL_KEY_PATH=/path/privkey.pem
# SSL_CERT_PATH=/path/fullchain.pem

# Только Electron: разрешить микрофон/WebRTC по http://IP без HTTPS (своя сеть)
# ELECTRON_INSECURE_ORIGINS=http://192.168.0.10:3000
# Electron + самоподписанный https://IP — принять сертификат
# ELECTRON_ALLOW_SELF_SIGNED=true

NODE_ENV=production
