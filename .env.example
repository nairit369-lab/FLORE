# Скопируйте в .env на сервере и заполните (не коммитьте .env с секретами).

# Обязательно в production (веб на хостинге): случайная длинная строка
JWT_SECRET=

# Порт даёт хостинг (Render/Railway/Heroku) через PORT — обычно не трогайте
# PORT=3000

# Слушать все интерфейсы (по умолчанию уже 0.0.0.0 в коде)
# HOST=0.0.0.0

# За nginx/Caddy/Render: иначе rate-limit и IP могут вести себя странно
TRUST_PROXY=1

# Один origin или список через запятую; для «разрешить всё» в dev: true
# CORS_ORIGIN=https://ваш-домен.ru

NODE_ENV=production
